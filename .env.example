# ══════════════════════════════════════════════════════════════════
# CodeMaker Configuration
# Copy this file to .env and fill in your values
# ══════════════════════════════════════════════════════════════════

# ─── System Prompt ───────────────────────────────────────────────
# Instruction sent to the AI alongside the screenshot
SYSTEM_PROMPT=Solve this in c and have no comments, no explanation whatsoever at all.

# ─── Trigger Sequence ────────────────────────────────────────────
TRIGGER_SEQUENCE=t,a,a,r,u,n

# ─── Screenshot ──────────────────────────────────────────────────
# Tool: grim, gnome-screenshot, spectacle, screencapture, pillow, or auto
# macOS uses screencapture by default; Linux auto-detects compositor
SCREENSHOT_TOOL=auto

# ─── Emergency Kill Combo ────────────────────────────────────────
KILL_COMBO=ctrl+shift+escape

# ─── Reset Combo ────────────────────────────────────────────────
# Jump back to observer mode instantly (cancels capture/playback)
RESET_COMBO=ctrl+shift+r

# ─── Keyboard Device (Linux only — ignored on macOS) ─────────────
# Leave empty for auto-detect. Set to /dev/input/eventX if needed.
# macOS uses Quartz CGEventTap (no device path needed).
KEYBOARD_DEVICE=


# ══════════════════════════════════════════════════════════════════
# AI PROVIDERS — set up to 5 API providers + 1 local model
# Providers are tried in PROVIDER_PRIORITY order.
# Leave unused slots empty/commented out.
# ══════════════════════════════════════════════════════════════════

# ─── Priority Order ──────────────────────────────────────────────
# Comma-separated: 1-5 for API slots, "local" for Ollama
# First in list = highest priority, others are fallbacks
PROVIDER_PRIORITY=2,3,1,4,5,local


# ─── Provider 1 ──────────────────────────────────────────────────
# Groq — fast inference, free tier
# Get a free API key at: https://console.groq.com
PROVIDER_1_TYPE=groq
PROVIDER_1_KEY=your_groq_key_here
# Available Groq vision models:
#   meta-llama/llama-4-scout-17b-16e-instruct   → Only available vision model on Groq
#   (Maverick was deprecated March 2026)
PROVIDER_1_MODEL=meta-llama/llama-4-scout-17b-16e-instruct


# ─── Provider 2 ──────────────────────────────────────────────────
# Gemini — best code quality, generous free tier
# Get a free API key at: https://aistudio.google.com/apikey
PROVIDER_2_TYPE=gemini
PROVIDER_2_KEY=your_gemini_key_here
# Available Gemini models:
#   gemini-2.5-flash         → Best balance of speed + intelligence (recommended)
#   gemini-2.0-flash         → Faster, slightly less capable
#   gemini-2.5-pro           → Most capable (very limited free tier)
PROVIDER_2_MODEL=gemini-2.5-flash


# ─── Provider 3 ──────────────────────────────────────────────────
# OpenRouter — aggregator, routes to cheapest provider
# Get free credit at: https://openrouter.ai
PROVIDER_3_TYPE=openrouter
PROVIDER_3_KEY=
# Available OpenRouter free vision models (May 2026):
#   google/gemma-4-31b-it:free                    → Best free vision (256K context)
#   nvidia/nemotron-3-nano-omni-30b-a3b:free      → Multimodal (text+image+video)
#   openrouter/free                               → Auto-routes to best free model
PROVIDER_3_MODEL=openrouter/free


# ─── Provider 4 ──────────────────────────────────────────────────
# Mistral — free tier available
# Get a key at: https://console.mistral.ai
PROVIDER_4_TYPE=mistral
PROVIDER_4_KEY=
# Available Mistral vision models:
#   mistral-small-latest      → Fast, affordable
#   pixtral-large-latest      → Best Mistral vision model
PROVIDER_4_MODEL=pixtral-large-latest


# ─── Provider 5 ──────────────────────────────────────────────────
# Together AI — $1 free credit on signup
# Get a key at: https://www.together.ai
PROVIDER_5_TYPE=together
PROVIDER_5_KEY=
# Available Together vision models:
#   meta-llama/Llama-4-Scout-17B-16E-Instruct  → Fast vision
#   Qwen/Qwen2.5-VL-72B-Instruct               → Best quality
PROVIDER_5_MODEL=meta-llama/Llama-4-Scout-17B-16E-Instruct


# ─── Custom OpenAI-compatible endpoint ───────────────────────────
# Uncomment and use any slot (1-5) for a custom endpoint:
# PROVIDER_5_TYPE=openai
# PROVIDER_5_KEY=your_key
# PROVIDER_5_MODEL=your-model-name
# PROVIDER_5_BASE_URL=https://your-api.example.com/v1

# ─── GitHub Models (free with GitHub account) ────────────────────
# Uncomment and use any slot. Get a token at:
# https://github.com/marketplace/models
# PROVIDER_5_TYPE=github
# PROVIDER_5_KEY=your_github_token
# PROVIDER_5_MODEL=gpt-4o-mini
# PROVIDER_5_BASE_URL=https://models.inference.ai.azure.com


# ══════════════════════════════════════════════════════════════════
# LOCAL MODEL (Ollama) — runs on your GPU, no API key needed
# Install Ollama: https://ollama.com
# Models are auto-downloaded on first use.
# ══════════════════════════════════════════════════════════════════

# ─── Option A: Single model (simple, uses one vision+code model) ───
# LOCAL_MODEL=qwen2.5vl:3b

# ─── Option B: Two-stage pipeline (recommended) ─────────────────
# Stage 1: Vision model extracts the question from the screenshot
# Stage 2: Code model generates the solution
# Models are loaded/unloaded sequentially so each gets full VRAM.
#
# Vision models (extract question from screenshot):
#   ┌─ 4 GB VRAM ─────────────────────────────────────────────────┐
#   │  minicpm-v                → ~1 GB, fast, good accuracy      │
#   │  moondream:latest         → ~1.5 GB, basic but lightweight  │
#   │  qwen2.5vl:3b            → ~2.5 GB, good quality           │
#   ├─ 6 GB VRAM ─────────────────────────────────────────────────┤
#   │  qwen2.5vl:7b            → ~5 GB, best extraction          │
#   └─────────────────────────────────────────────────────────────┘
#
# Code models (generate the solution):
#   ┌─ 4 GB VRAM ─────────────────────────────────────────────────┐
#   │  qwen2.5-coder:3b        → ~2.5 GB, good for simple code   │
#   │  qwen2.5-coder:1.5b      → ~1.5 GB, fast but basic         │
#   ├─ 6 GB VRAM ─────────────────────────────────────────────────┤
#   │  qwen2.5-coder:7b        → ~5 GB, best quality             │
#   │  codegemma:7b            → ~5 GB, Google's code model      │
#   ├─ 12+ GB VRAM ───────────────────────────────────────────────┤
#   │  deepseek-coder-v2:16b   → ~10 GB, excellent               │
#   └─────────────────────────────────────────────────────────────┘
#
# Recommended combos:
#   4 GB VRAM → minicpm-v      + qwen2.5-coder:3b
#   6 GB VRAM → minicpm-v      + qwen2.5-coder:7b
#   8 GB VRAM → qwen2.5vl:7b   + qwen2.5-coder:7b

LOCAL_VISION_MODEL=minicpm-v
# LOCAL_CODE_MODEL=qwen2.5-coder:7b

# ─── Quality Mode (optional) ────────────────────────────────────
# Set this to use a LARGER code model that splits across GPU + RAM.
# Much better code quality, but slower (~5-10 tok/s vs ~20+ tok/s).
# When set, the pipeline always uses this instead of LOCAL_CODE_MODEL.
# If you don't want to use Quality Mode, comment this out and uncomment LOCAL_CODE_MODEL above.
#
# Quality code models (GPU+CPU split):
#   ┌─ 6 GB VRAM + 8 GB RAM ──────────────────────────────────────┐
#   │  qwen2.5-coder:14b        → ~9 GB, excellent quality        │
#   │  deepseek-coder-v2:16b    → ~10 GB, very strong             │
#   ├─ 6 GB VRAM + 12 GB RAM ─────────────────────────────────────┤
#   │  qwen2.5-coder:32b        → ~20 GB, near-frontier quality   │
#   └──────────────────────────────────────────────────────────────┘
#
# Recommended: qwen2.5-coder:14b (best quality/speed balance)
LOCAL_CODE_MODEL_QUALITY=qwen2.5-coder:14b

# Prompt for the vision extraction step (what to tell the vision model)
LOCAL_VISION_PROMPT=Extract only the coding problem or question, or questions from this screenshot. Ignore all UI elements, navigation bars, buttons, ads, and unrelated text. Output ONLY the problem statement/statements. Do not solve it.

# Leave LOCAL_MODEL empty when using the two-stage pipeline
LOCAL_MODEL=
OLLAMA_URL=http://localhost:11434
